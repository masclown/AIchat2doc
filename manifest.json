{
  "manifest_version": 3,
  "name": "AIchat2doc",
  "version": "0.0.13",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://*.kimi.com/*",
        "https://www.doubao.com/*"
      ],
      "js": [
        "turndown.js",
        "turndown-plugin-gfm.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}