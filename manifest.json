{
  "manifest_version": 3,
  "name": "Gemini2Obsidian",
  "version": "0.0.6",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "turndown.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}